CONTRACT_REALISM_MODE=advisory
CONTRACT_REALISM_REPORT_MD=../../output/contracts-test-audit/realism-report.md
CONTRACT_REALISM_REPORT_JSON=../../output/contracts-test-audit/realism-report.json

