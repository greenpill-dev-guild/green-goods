dist
dist-ssr

# Foundry build artifacts - ignore all out/ directories
out/
**/out/

# Keep only the specific ABIs imported by packages/shared
# Step 1: Un-ignore the out/ directory so git looks inside
!packages/contracts/out/
# Step 2: Re-ignore everything inside it
packages/contracts/out/*
# Step 3: Un-ignore only the subdirectories we need
!packages/contracts/out/Garden.sol/
!packages/contracts/out/Action.sol/
!packages/contracts/out/EAS.sol/
!packages/contracts/out/ENS.sol/
!packages/contracts/out/IHats.sol/
# Step 4: Re-ignore everything inside those subdirectories
packages/contracts/out/Garden.sol/*
packages/contracts/out/Action.sol/*
packages/contracts/out/EAS.sol/*
packages/contracts/out/ENS.sol/*
packages/contracts/out/IHats.sol/*
# Step 5: Un-ignore only the specific ABI files we need
!packages/contracts/out/Garden.sol/GardenAccount.json
!packages/contracts/out/Garden.sol/GardenToken.json
!packages/contracts/out/Action.sol/ActionRegistry.json
!packages/contracts/out/EAS.sol/MockEAS.json
!packages/contracts/out/ENS.sol/GreenGoodsENS.json
!packages/contracts/out/IHats.sol/IHats.json

