{
  "name": "@green-goods/agent",
  "version": "0.4.0",
  "private": true,
  "type": "module",
  "main": "src/index.ts",
  "scripts": {
    "dev": "bun --watch src/index.ts",
    "build": "tsc",
    "start": "bun dist/index.js",
    "lint": "oxlint src",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "test:ui": "vitest --ui",
    "format": "biome format --write src",
    "format:check": "biome format src",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@fastify/sensible": "^6.0.0",
    "@green-goods/shared": "workspace:*",
    "@storacha/client": "^1.8.23",
    "multiformats": "^13.4.2",
    "@xenova/transformers": "^2.17.1",
    "dotenv": "^16.4.5",
    "fastify": "^5.0.0",
    "pino": "^10.1.0",
    "pino-pretty": "^13.1.3",
    "posthog-node": "5.17.2",
    "telegraf": "^4.16.3",
    "viem": "^2.43.4"
  },
  "devDependencies": {
    "@faker-js/faker": "^10.2.0",
    "@types/node": "^24.2.1",

    "@vitest/coverage-v8": "^4.0.18",
    "@vitest/ui": "^4.0.18",
    "bun-types": "latest",
    "tsx": "^4.7.2",
    "typescript": "^5.9.3",
    "vitest": "^4.0.16"
  }
}
