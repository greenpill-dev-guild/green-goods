{
  "name": "@green-goods/agent",
  "version": "1.1.0",
  "private": true,
  "type": "module",
  "main": "src/index.ts",
  "scripts": {
    "dev": "APP_ENV=development bun --env-file=../../.env --watch src/index.ts",
    "build": "tsc",
    "start": "APP_ENV=production bun --env-file=../../.env dist/index.js",
    "lint": "bun --bun run oxlint src",
    "test": "APP_ENV=test vitest run",
    "test:watch": "APP_ENV=test vitest",
    "test:coverage": "APP_ENV=test bun scripts/run-coverage.mjs",
    "test:ui": "APP_ENV=test vitest --ui",
    "format": "biome format --write src",
    "format:check": "biome format src",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@green-goods/shared": "workspace:*",
    "@xenova/transformers": "^2.17.1",
    "hono": "^4.11.3",
    "pino": "^10.1.0",
    "pino-pretty": "^13.1.3",
    "telegraf": "^4.16.3",
    "viem": "^2.43.4"
  },
  "devDependencies": {
    "@faker-js/faker": "^10.2.0",
    "@types/node": "^24.2.1",

    "@vitest/coverage-v8": "^4.0.18",
    "@vitest/ui": "^4.0.18",
    "bun-types": "latest",
    "typescript": "^5.9.3",
    "vitest": "^4.0.16"
  }
}
