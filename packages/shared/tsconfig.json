{
  "compilerOptions": {
    "module": "ESNext",
    "moduleResolution": "bundler",
    "resolvePackageJsonExports": true,
    "target": "ES2022",
    "lib": ["ESNext", "DOM", "DOM.Iterable"],
    "types": ["node"],
    "resolveJsonModule": true,
    "allowImportingTsExtensions": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "strict": true,
    "noEmit": true,
    "verbatimModuleSyntax": true,
    "jsx": "preserve",
    "baseUrl": ".",
    "paths": {
      "@shared/*": ["./src/*"],
      "@green-goods/contracts/deployments/*": ["../contracts/deployments/*"],
      "@green-goods/contracts/abis/*": ["../contracts/abis/*"]
    }
  },
  "include": ["src/**/*.ts", "src/**/*.tsx", "src/**/*.d.ts", "../../env.d.ts"],
  "exclude": [
    "node_modules",
    "dist",
    "src/__tests__/**",
    "src/__mocks__/**",
    "**/__tests__/**",
    "**/*.test.ts",
    "**/*.test.tsx"
  ],
  "plugins": [
    {
      "name": "gql.tada/ts-plugin",
      "schemas": [
        {
          "name": "Indexer",
          "schema": "http://localhost:8080/v1/graphql",
          "tadaOutputLocation": "./src/types/indexer.d.ts"
        },
        {
          "name": "EAS",
          "schema": "https://arbitrum.easscan.org/graphql",
          "tadaOutputLocation": "./src/types/eas.d.ts"
        }
      ]
    }
  ]
}
