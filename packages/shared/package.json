{
  "name": "@green-goods/shared",
  "version": "1.1.0",
  "private": true,
  "type": "module",
  "engines": {
    "node": ">=22.12.0 <23",
    "bun": ">=1.x"
  },
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": "./src/index.ts",
    "./components": "./src/components/index.ts",
    "./cards": "./src/components/Cards/index.ts",
    "./display": "./src/components/Display/index.ts",
    "./badge": "./src/components/Badge/index.ts",
    "./config": "./src/config/index.ts",
    "./hooks": "./src/hooks/index.ts",
    "./i18n": "./src/i18n/index.ts",
    "./lib/env": "./src/lib/env.ts",
    "./i18n/en": "./src/i18n/en.json",
    "./i18n/es": "./src/i18n/es.json",
    "./i18n/pt": "./src/i18n/pt.json",
    "./mocks": "./src/__mocks__/index.ts",
    "./mocks/browser": "./src/__mocks__/browser/index.ts",
    "./mocks/server": "./src/__mocks__/server/index.ts",
    "./modules": "./src/modules/index.ts",
    "./service-worker": "./src/modules/app/service-worker-registration.ts",
    "./providers": "./src/providers/index.ts",
    "./public-contracts": "./src/public-contracts/index.ts",
    "./stores": "./src/stores/index.ts",
    "./styles": "./src/styles/theme.css",
    "./styles/theme.css": "./src/styles/theme.css",
    "./styles/utilities.css": "./src/styles/utilities.css",
    "./toast": "./src/components/toast.ts",
    "./types": "./src/types/index.ts",
    "./utils": "./src/utils/index.ts",
    "./workflows": "./src/workflows/index.ts",
    "./__tests__/setupTests.base": "./src/__tests__/setupTests.base.ts",
    "./testing": "./src/__tests__/test-utils/index.ts"
  },
  "scripts": {
    "lint": "bun --bun run oxlint src",
    "format": "biome format --write .",
    "format:check": "biome format .",
    "build": "echo 'Shared package uses source files directly - no build needed'",
    "typecheck": "tsc --noEmit",
    "test": "node ../../scripts/dev/node-cli.js vitest run --exclude src/__tests__/integration/** --exclude src/**/*.live.test.ts",
    "test:live": "RUN_LIVE_RPC_TESTS=true node ../../scripts/dev/node-cli.js vitest run src/__tests__/integration/arbitrum-yield-data.test.ts src/__tests__/utils/blockchain/aave.live.test.ts",
    "test:watch": "vitest --standalone",
    "coverage": "node ../../scripts/dev/node-cli.js vitest run --coverage",
    "storybook:prepare-design-assets": "node .storybook/prepare-design-assets.mjs",
    "prestorybook": "lsof -t -iTCP:6006 -sTCP:LISTEN | xargs kill -9 2>/dev/null || true",
    "storybook": "bun run storybook:prepare-design-assets && node ../../scripts/dev/node-cli.js storybook dev -p 6006 --ci",
    "build-storybook": "bun run storybook:prepare-design-assets && STORYBOOK_STATIC_BUILD=true node ../../scripts/dev/node-cli.js storybook build -o storybook-static && node .storybook/copy-static-assets.mjs",
    "check:stories": "bun run ../../scripts/quality/check-story-coverage.ts",
    "check:story-quality": "bun run ../../scripts/quality/check-story-quality.ts",
    "test:stories:ci": "node ../../scripts/dev/run-storybook-vitest-ci.mjs",
    "chromatic": "chromatic --storybook-build-dir storybook-static"
  },
  "dependencies": {
    "@green-goods/contracts": "workspace:*",
    "@hypercerts-org/contracts": "^2.0.0-alpha.0",
    "@hypercerts-org/marketplace-sdk": "^0.8.0",
    "@hypercerts-org/sdk": "^2.9.1",
    "@radix-ui/react-popover": "^1.1.15",
    "@react-spring/web": "^10.0.3",
    "@reown/appkit": "^1.8.14",
    "@reown/appkit-adapter-wagmi": "^1.8.14",
    "@use-gesture/react": "^10.3.1",
    "@wagmi/core": "^2.22.1",
    "browser-image-compression": "^2.0.2",
    "clsx": "2.1.1",
    "embla-carousel-react": "^8.6.0",
    "ethers": "^6.16.0",
    "gql.tada": "^1.8.10",
    "graphql": "^16.10.0",
    "graphql-request": "^7.1.2",
    "permissionless": "^0.2.57",
    "react-day-picker": "^9.13.0",
    "react-router-dom": "^7.12.0",
    "tailwind-merge": "3.0.2",
    "tailwind-variants": "3.2.2"
  },
  "peerDependencies": {
    "@ethereum-attestation-service/eas-sdk": "^2.7.0",
    "@hookform/resolvers": "^5.2.2",
    "@radix-ui/react-dialog": "^1.1.15",
    "@radix-ui/react-select": "^2.1.2",
    "@remixicon/react": "^4.6.0",
    "@tanstack/react-query": "^5.85.3",
    "@xstate/react": "^6.1.0",
    "posthog-js": "^1.315.0",
    "idb": "^8.0.3",
    "idb-keyval": "^6.2.2",
    "react": "^19.2.3",
    "react-dom": "^19.2.3",
    "react-hook-form": "^7.53.0",
    "react-hot-toast": "^2.4.1",
    "react-intl": "^8.0.0",
    "react-select": "^5.8.0",
    "viem": "^2.43.4",
    "wagmi": "^2.19.5",
    "xstate": "^5.30.0",
    "zod": "^4.3.5",
    "zustand": "^5.0.6"
  },
  "devDependencies": {
    "@chromatic-com/storybook": "5.1.2",
    "@graphql-typed-document-node/core": "^3.2.0",
    "@storybook/addon-a11y": "10.3.5",
    "@storybook/addon-docs": "10.3.5",
    "@storybook/addon-mcp": "0.6.0",
    "@storybook/addon-vitest": "10.3.5",
    "@storybook/react": "10.3.5",
    "@storybook/react-vite": "10.3.5",
    "@tailwindcss/vite": "^4.1.11",
    "@vitest/browser": "4.0.18",
    "@vitest/browser-playwright": "4.0.18",
    "@vitest/runner": "4.0.18",
    "chromatic": "16.5.0",
    "storybook": "10.3.5"
  }
}
