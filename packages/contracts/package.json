{
  "name": "@green-goods/contracts",
  "version": "0.4.0",
  "private": true,
  "description": "Contracts for Green Goods Protocol",
  "exports": {
    "./deployments/*.json": "./deployments/*.json",
    "./abis/*.json": "./abis/*.json"
  },
  "scripts": {
    "predev": "lsof -ti:8545 | xargs kill -9 2>/dev/null || true",
    "dev": "anvil --config-out localhost.json",
    "format": "forge fmt",
    "lint": "forge fmt && solhint --config ./.solhint.json 'src/**/*.sol' --ignore-path .solhintignore",
    "lint:fix": "forge fmt && solhint --config ./.solhint.json 'src/**/*.sol' --ignore-path .solhintignore --fix",
    "build": "bun script/utils/build-adaptive.ts",
    "postbuild": "bun script/build-abis.ts",
    "build:changed": "bun script/utils/build-changed.ts",
    "build:target": "bun script/utils/build-target.ts",
    "build:abis": "bun script/build-abis.ts",
    "build:fast": "GG_CONTRACTS_BUILD_MODE=fast bun run build",
    "build:full": "GG_CONTRACTS_BUILD_MODE=full bun run build",
    "clean:artifacts": "rm -rf out out-* cache cache-*",
    "build:fresh": "bun run clean:artifacts && forge build",
    "build:core": "forge build --skip test --skip script",
    "test": "forge test --no-match-contract 'E2E'",
    "test:fast": "forge test --no-match-contract 'E2E|Fork'",
    "test:lite": "forge test --no-match-path 'test/integration/Garden*|test/unit/GardenAccount*|test/unit/GardenToken*|test/E2E*|test/Fuzz*|test/Gas*|test/Storage*|test/Upgrade*|test/fork/e2e/*|test/fork/eas/*|test/fork/gardens/*'",
    "test:gas": "forge test --gas-report --no-match-contract 'E2E'",
    "test:match": "forge test --match-path",
    "test:e2e": "bun run build && forge test --match-contract 'E2EWorkflowTest' -vv && set -a && . ../../.env 2>/dev/null || true && set +a && forge test --match-contract 'ArbitrumKarmaGAPForkTest' -vv && forge test --match-contract 'SepoliaKarmaGAPForkTest' -vv && forge test --match-path 'test/fork/e2e/FullProtocolE2E.t.sol' -vvv && forge test --match-path 'test/fork/e2e/SepoliaExtendedE2E.t.sol' -vvv && forge test --match-path 'test/fork/e2e/Arbitrum*.t.sol' -vvv",
    "test:e2e:workflow": "bun run build && forge test --match-contract 'E2EWorkflowTest' -vv",
    "test:e2e:karma": "bun run build && set -a && . ../../.env 2>/dev/null || true && set +a && forge test --match-contract 'ArbitrumKarmaGAPForkTest' -vv && forge test --match-contract 'SepoliaKarmaGAPForkTest' -vv",
    "test:e2e:sepolia": "bun run build && set -a && . ../../.env 2>/dev/null || true && set +a && forge test --match-path 'test/fork/e2e/FullProtocolE2E.t.sol' -vvv && forge test --match-path 'test/fork/e2e/SepoliaExtendedE2E.t.sol' -vvv",
    "test:e2e:arbitrum": "bun run build && set -a && . ../../.env 2>/dev/null || true && set +a && forge test --match-path 'test/fork/e2e/Arbitrum*.t.sol' -vvv",
    "test:e2e:celo": "bun run build && set -a && . ../../.env 2>/dev/null || true && set +a && forge test --match-test 'testFork.*Celo|test_celo.*' -vvv",
    "test:fork": "set -a && . ../../.env 2>/dev/null || true && set +a && forge test --match-path 'test/fork/**' -vvv",
    "test:fork:protocol": "set -a && . ../../.env 2>/dev/null || true && set +a && forge test --match-path 'test/fork/**' --no-match-test '.*[cC]elo.*|.*[uU]nlock.*' -vvv",
    "test:audit:realism": "bash ../../scripts/check-contract-test-realism.sh --mode ${CONTRACT_REALISM_MODE:-advisory} --report-md ${CONTRACT_REALISM_REPORT_MD:-../../output/contracts-test-audit/realism-report.md} --report-json ${CONTRACT_REALISM_REPORT_JSON:-../../output/contracts-test-audit/realism-report.json}",
    "test:audit:realism:tooling": "bash ../../scripts/validate-contract-test-realism-tooling.sh",
    "test:audit:coverage": "bash ../../scripts/run-contract-coverage-audit.sh",
    "test:audit:full": "bun run test:audit:realism:tooling && bun run test:audit:realism && bun run test:audit:coverage",
    "deploy": "bun script/deploy.ts core",
    "deploy:dry:sepolia": "bun script/deploy.ts core --network sepolia --dry-run",
    "deploy:dry:arbitrum": "bun script/deploy.ts core --network arbitrum --dry-run",
    "deploy:dry:celo": "bun script/deploy.ts core --network celo --dry-run",
    "deploy:dry:mainnet": "bun script/deploy.ts core --network mainnet --dry-run",
    "deploy:preflight:sepolia": "bun script/deploy.ts core --network sepolia --dry-run --pure-simulation",
    "deploy:preflight:arbitrum": "bun script/deploy.ts core --network arbitrum --dry-run --pure-simulation",
    "deploy:preflight:celo": "bun script/deploy.ts core --network celo --dry-run --pure-simulation",
    "deploy:preflight:mainnet": "bun script/deploy.ts core --network mainnet --dry-run --pure-simulation",
    "deploy:testnet": "bun deploy:sepolia",
    "deploy:sepolia": "bun script/deploy.ts core --network sepolia --broadcast",
    "deploy:arbitrum": "bun script/deploy.ts core --network arbitrum --broadcast",
    "deploy:celo": "bun script/deploy.ts core --network celo --broadcast --update-schemas",
    "deploy:mainnet": "bun script/deploy.ts core --network mainnet --broadcast",
    "deploy:octant-factory": "bun script/deploy.ts octant-factory",
    "deploy:octant-factory:dry:sepolia": "bun script/deploy.ts octant-factory --network sepolia --dry-run --pure-simulation",
    "deploy:octant-factory:dry:arbitrum": "bun script/deploy.ts octant-factory --network arbitrum --dry-run --pure-simulation",
    "deploy:octant-factory:dry:celo": "bun script/deploy.ts octant-factory --network celo --dry-run --pure-simulation",
    "deploy:octant-factory:sepolia": "bun script/deploy.ts octant-factory --network sepolia --broadcast",
    "deploy:octant-factory:arbitrum": "bun script/deploy.ts octant-factory --network arbitrum --broadcast",
    "deploy:octant-factory:celo": "bun script/deploy.ts octant-factory --network celo --broadcast",
    "verify:post-deploy": "bun script/utils/post-deploy-verify.ts",
    "verify:post-deploy:sepolia": "bun script/utils/post-deploy-verify.ts --network sepolia",
    "verify:post-deploy:arbitrum": "bun script/utils/post-deploy-verify.ts --network arbitrum",
    "verify:post-deploy:celo": "bun script/utils/post-deploy-verify.ts --network celo",
    "verify:post-deploy:mainnet": "bun script/utils/post-deploy-verify.ts --network mainnet",
    "verify:post-deploy:indexer:sepolia": "bun script/utils/post-deploy-verify.ts --network sepolia --check-indexer-runtime",
    "verify:post-deploy:indexer:arbitrum": "bun script/utils/post-deploy-verify.ts --network arbitrum --check-indexer-runtime",
    "verify:post-deploy:indexer:mainnet": "bun script/utils/post-deploy-verify.ts --network mainnet --check-indexer-runtime",
    "verify:post-deploy:indexer:local:sepolia": "bun script/utils/post-deploy-verify.ts --network sepolia --check-indexer-runtime --skip-local-indexer-start",
    "verify:post-deploy:indexer:local:arbitrum": "bun script/utils/post-deploy-verify.ts --network arbitrum --check-indexer-runtime --skip-local-indexer-start",
    "verify:post-deploy:indexer:local:mainnet": "bun script/utils/post-deploy-verify.ts --network mainnet --check-indexer-runtime --skip-local-indexer-start",
    "verify:etherscan:sepolia": "bun script/utils/post-deploy-verify.ts --network sepolia --check-etherscan --skip-indexer",
    "verify:etherscan:arbitrum": "bun script/utils/post-deploy-verify.ts --network arbitrum --check-etherscan --skip-indexer",
    "verify:etherscan:celo": "bun script/utils/post-deploy-verify.ts --network celo --check-etherscan --skip-indexer",
    "upgrade": "bun script/upgrade.ts",
    "upgrade:dry:sepolia": "bun script/upgrade.ts all --network sepolia --dry-run --pure-simulation",
    "upgrade:dry:arbitrum": "bun script/upgrade.ts all --network arbitrum --dry-run --pure-simulation",
    "upgrade:dry:celo": "bun script/upgrade.ts all --network celo --dry-run --pure-simulation",
    "upgrade:sepolia": "bun script/upgrade.ts all --network sepolia --broadcast",
    "upgrade:arbitrum": "bun script/upgrade.ts all --network arbitrum --broadcast",
    "upgrade:celo": "bun script/upgrade.ts all --network celo --broadcast",
    "status": "bun script/deploy.ts status",
    "envio:local": "bun script/utils/envio-integration.ts enable-local",
    "envio:cleanup": "bun script/utils/envio-integration.ts cleanup",
    "ipfs:upload": "bun script/utils/ipfs-uploader.ts",
    "ipfs:cache": "cat .ipfs-cache.json"
  },
  "dependencies": {
    "@chainlink/contracts-ccip": "^1.6.4",
    "@ensdomains/ens-contracts": "^1.6.2",
    "@ethereum-attestation-service/eas-contracts": "^1.8.0",
    "@openzeppelin/contracts-4.8.3": "npm:@openzeppelin/contracts@4.8.3",
    "@openzeppelin/contracts-5.0.2": "npm:@openzeppelin/contracts@5.0.2",
    "@openzeppelin/contracts-upgradeable": "4.9.6",
    "@storacha/client": "^1.8.23",
    "dotenv": "^16.4.5",
    "js-yaml": "^4.1.1"
  },
  "devDependencies": {
    "@types/js-yaml": "^4.0.9",
    "bun-types": "latest",
    "solhint": "^6.0.1"
  }
}
