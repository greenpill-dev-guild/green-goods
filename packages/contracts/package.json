{
  "name": "@green-goods/contracts",
  "version": "0.4.0",
  "private": true,
  "description": "Contracts for Green Goods Protocol",
  "scripts": {
    "predev": "lsof -ti:8545 | xargs kill -9 2>/dev/null || true",
    "dev": "anvil --config-out localhost.json",
    "format": "forge fmt",
    "lint": "forge fmt && solhint --config ./.solhint.json 'src/**/*.sol' --ignore-path .solhintignore",
    "lint:fix": "forge fmt && solhint --config ./.solhint.json 'src/**/*.sol' --ignore-path .solhintignore --fix",
    "build": "bun script/utils/build-adaptive.ts",
    "build:fast": "forge build --skip test --skip script",
    "build:full": "forge build",
    "build:fresh": "rm -rf out cache && forge build",
    "build:core": "forge build --skip test --skip script",
    "test": "forge test --no-match-contract 'E2E'",
    "test:fast": "forge test --no-match-contract 'E2E|Fork'",
    "test:lite": "forge test --no-match-path 'test/integration/Garden*|test/unit/GardenAccount*|test/unit/GardenToken*|test/E2E*|test/Fuzz*|test/Gas*|test/Storage*|test/Upgrade*|test/fork/e2e/*|test/fork/eas/*|test/fork/gardens/*'",
    "test:gas": "forge test --gas-report --no-match-contract 'E2E'",
    "test:match": "forge test --match-path",
    "test:e2e": "bun run build && forge test --match-contract 'E2EWorkflowTest' -vv && dotenv -e ../../.env -- forge test --match-contract 'E2EKarmaGAPForkTest' -vv",
    "test:e2e:workflow": "bun run build && forge test --match-contract 'E2EWorkflowTest' -vv",
    "test:e2e:karma": "bun run build && dotenv -e ../../.env -- forge test --match-contract 'E2EKarmaGAPForkTest' -vv",
    "test:e2e:sepolia": "bun run build && dotenv -e ../../.env -- forge test --match-test 'testFork.*Sepolia' -vvv",
    "test:e2e:arbitrum": "bun run build && dotenv -e ../../.env -- forge test --match-test 'testFork.*Arbitrum' -vvv",
    "test:e2e:celo": "bun run build && dotenv -e ../../.env -- forge test --match-test 'testFork.*Celo' -vvv",
    "test:fork": "dotenv -e ../../.env -- forge test --match-path 'test/fork/**' -vvv",
    "deploy": "bun script/deploy.ts core",
    "deploy:dry:sepolia": "bun script/deploy.ts core --network sepolia --dry-run --pure-simulation",
    "deploy:dry:arbitrum": "bun script/deploy.ts core --network arbitrum --dry-run --pure-simulation",
    "deploy:dry:celo": "bun script/deploy.ts core --network celo --dry-run --pure-simulation",
    "deploy:sepolia": "bun script/deploy.ts core --network sepolia --broadcast",
    "deploy:arbitrum": "bun script/deploy.ts core --network arbitrum --broadcast",
    "deploy:celo": "bun script/deploy.ts core --network celo --broadcast --update-schemas",
    "deploy:octant-factory": "bun script/deploy.ts octant-factory",
    "deploy:octant-factory:dry:sepolia": "bun script/deploy.ts octant-factory --network sepolia --dry-run --pure-simulation",
    "deploy:octant-factory:dry:arbitrum": "bun script/deploy.ts octant-factory --network arbitrum --dry-run --pure-simulation",
    "deploy:octant-factory:dry:celo": "bun script/deploy.ts octant-factory --network celo --dry-run --pure-simulation",
    "deploy:octant-factory:sepolia": "bun script/deploy.ts octant-factory --network sepolia --broadcast",
    "deploy:octant-factory:arbitrum": "bun script/deploy.ts octant-factory --network arbitrum --broadcast",
    "deploy:octant-factory:celo": "bun script/deploy.ts octant-factory --network celo --broadcast",
    "upgrade": "bun script/upgrade.ts",
    "upgrade:dry:sepolia": "bun script/upgrade.ts all --network sepolia --dry-run --pure-simulation",
    "upgrade:dry:arbitrum": "bun script/upgrade.ts all --network arbitrum --dry-run --pure-simulation",
    "upgrade:dry:celo": "bun script/upgrade.ts all --network celo --dry-run --pure-simulation",
    "upgrade:sepolia": "bun script/upgrade.ts all --network sepolia --broadcast",
    "upgrade:arbitrum": "bun script/upgrade.ts all --network arbitrum --broadcast",
    "upgrade:celo": "bun script/upgrade.ts all --network celo --broadcast",
    "status": "bun script/deploy.ts status",
    "envio:local": "bun script/utils/envio-integration.ts enable-local",
    "envio:cleanup": "bun script/utils/envio-integration.ts cleanup",
    "ipfs:upload": "bun script/utils/ipfs-uploader.ts",
    "ipfs:cache": "cat .ipfs-cache.json"
  },
  "dependencies": {
    "@chainlink/contracts-ccip": "^1.6.4",
    "@ensdomains/ens-contracts": "^1.6.2",
    "@ethereum-attestation-service/eas-contracts": "^1.8.0",
    "@openzeppelin/contracts-4.8.3": "npm:@openzeppelin/contracts@4.8.3",
    "@openzeppelin/contracts-5.0.2": "npm:@openzeppelin/contracts@5.0.2",
    "@openzeppelin/contracts-upgradeable": "4.9.6",
    "@storacha/client": "^1.8.23",
    "dotenv": "^16.4.5",
    "js-yaml": "^4.1.0"
  },
  "devDependencies": {
    "@types/js-yaml": "^4.0.9",
    "bun-types": "latest",
    "solhint": "^6.0.1"
  }
}
