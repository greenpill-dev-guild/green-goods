# ==========================================
# API PACKAGE ENVIRONMENT VARIABLES 🖥️
# ==========================================
# 
# 🚀 RECOMMENDED: Use the root .env file for full development
#    cp ../../.env.example ../../.env
#    # Edit ../../.env with your values
#    pnpm run dev (from root)
#
# 🔧 ISOLATION: For API-only development, use variables below
#    cp ../../.env.example .env
#    # Edit .env to keep only API variables
#    pnpm run dev (from this directory)

# ==========================================
# REQUIRED FOR API 🖥️
# ==========================================
PORT="3000"                                        # Server port
NODE_ENV="development"                             # Environment mode

# Sessions (used for WebAuthn + auth)
SESSION_SECRET="change-me"                          # Keep secret in production

# WebAuthn Relying Party (Passkeys)
RP_ID="localhost"                                   # e.g., greengoods.app in prod
RP_ORIGIN="http://localhost:3001"                   # e.g., https://greengoods.app in prod
RP_NAME="GreenGoods"                                # Display name shown in passkey prompts

# Chain & Pimlico (shared with client)
VITE_CHAIN_ID="44787"                               # 44787=Celo Alfajores (testnet)
PIMLICO_API_KEY="your-pimlico-api-key"              # Pimlico API key (bundler/paymaster)
# Optional separate key for sponsorship (else API_KEY is used)
# PIMLICO_PAYMASTER_API_KEY="your-pimlico-paymaster-key"

# ==========================================
# 📚 API DEVELOPMENT GUIDE
# ==========================================
#
# FULL STACK (Recommended):
#   cd ../../ && cp .env.example .env && pnpm run dev
#
# API ONLY:
#   cp ../../.env.example .env
#   pnpm run dev
#
# DATABASE SETUP:
#   # Set up PostgreSQL database
#   # Set up Redis for sessions/cache
#
# TESTING:
#   pnpm run test                     # API tests
#   pnpm run build                    # Production build
#
# The API provides:
#   - User authentication via Privy
#   - File upload endpoints
#   - Blockchain interaction
#   - User data management
