{
  "name": "@green-goods/client",
  "version": "1.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "predev": "node ../../scripts/dev/check-port.js 3001 client",
    "dev": "APP_ENV=development node ../../scripts/dev/node-cli.js vite",
    "test": "APP_ENV=test node ../../scripts/dev/node-cli.js vitest run",
    "test:watch": "APP_ENV=test vitest --standalone",
    "coverage": "APP_ENV=test node ../../scripts/dev/node-cli.js vitest run --coverage",
    "format": "biome format --write .",
    "format:check": "biome format .",
    "lint": "bun --bun run oxlint src",
    "build": "APP_ENV=production tsc --noEmit && node ../../scripts/dev/node-cli.js vite build && bun run check:pwa-precache && node ../../scripts/dev/remove-public-sourcemaps.js dist",
    "build:deploy": "bun run build",
    "check:pwa-precache": "node scripts/check-pwa-precache-budget.mjs",
    "preview": "APP_ENV=production bun --bun vite preview",
    "formatjs": "formatjs extract"
  },
  "dependencies": {
    "@ethereum-attestation-service/eas-sdk": "2.7.0",
    "@green-goods/shared": "workspace:*",
    "@hookform/resolvers": "^5.2.2",
    "@radix-ui/react-accordion": "^1.2.3",
    "@radix-ui/react-avatar": "^1.1.3",
    "@radix-ui/react-dialog": "^1.1.15",
    "@radix-ui/react-select": "^2.1.6",
    "@radix-ui/react-slot": "^1.1.2",
    "@remixicon/react": "^4.6.0",
    "@sentry/react": "^10.53.1",
    "@tailwindcss/vite": "^4.1.11",
    "@tanstack/react-query": "^5.85.3",
    "@tanstack/react-query-persist-client": "^5.85.3",
    "embla-carousel-react": "^8.6.0",
    "idb": "^8.0.3",
    "idb-keyval": "^6.2.2",
    "posthog-js": "^1.315.0",
    "qrcode.react": "^4.2.0",
    "react": "^19.2.3",
    "react-device-frameset": "1.3.4",
    "react-dom": "^19.2.3",
    "react-helmet-async": "^2.0.5",
    "react-hook-form": "^7.53.0",
    "react-hot-toast": "^2.4.1",
    "react-intl": "^8.0.0",
    "react-router-dom": "^7.12.0",
    "react-window": "^1.8.10",
    "tailwind-merge": "3.0.2",
    "tailwind-variants": "3.2.2",
    "thirdweb": "^5.105.40",
    "viem": "^2.43.4",
    "wagmi": "^2.19.5",
    "zod": "^4.3.5",
    "zustand": "^5.0.6"
  },
  "devDependencies": {
    "@formatjs/cli": "^6.7.1",
    "@reown/appkit": "^1.8.14",
    "@sentry/vite-plugin": "^5.3.0",
    "@vitejs/plugin-react": "^5.1.2",
    "babel-plugin-react-compiler": "^1.0.0",
    "opentype.js": "^2.0.0",
    "tailwindcss": "^4.1.11",
    "typescript": "^5.9.3",
    "vite": "^7.3.0",
    "vite-plugin-mkcert": "^1.17.8",
    "vite-plugin-pwa": "^1.0.2",
    "workbox-build": "^7.3.0",
    "workbox-window": "^7.3.0"
  }
}
