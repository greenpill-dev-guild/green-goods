{
  "hooks": {
    "SessionStart": [
      {
        "matcher": "startup|resume|compact",
        "hooks": [
          {
            "type": "command",
            "command": "bash \"$(git rev-parse --show-toplevel)/.codex/hooks/session_context.sh\"",
            "statusMessage": "Loading Green Goods Codex context..."
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "bash \"$(git rev-parse --show-toplevel)/.codex/hooks/pre_tool_policy.sh\"",
            "statusMessage": "Checking Green Goods command policy..."
          }
        ]
      },
      {
        "matcher": "apply_patch|Write|Edit",
        "hooks": [
          {
            "type": "command",
            "command": "bash \"$(git rev-parse --show-toplevel)/.codex/hooks/edit_policy.sh\"",
            "statusMessage": "Checking Green Goods edit policy..."
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "apply_patch|Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "bash \"$(git rev-parse --show-toplevel)/.codex/hooks/post_tool_context.sh\"",
            "statusMessage": "Adding Green Goods post-edit context..."
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash \"$(git rev-parse --show-toplevel)/.codex/hooks/stop_guard.sh\"",
            "statusMessage": "Checking Green Goods stop context..."
          }
        ]
      }
    ]
  }
}
