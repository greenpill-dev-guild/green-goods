{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "additionalProperties": false,
  "properties": {
    "status": {
      "type": "string",
      "enum": ["success", "partial", "failed"],
      "description": "Did the task complete successfully?"
    },
    "files_created": {
      "type": "array",
      "items": { "type": "string" },
      "description": "New files created (relative paths)"
    },
    "files_modified": {
      "type": "array",
      "items": { "type": "string" },
      "description": "Existing files modified (relative paths)"
    },
    "tests_passed": {
      "type": "boolean",
      "description": "Did validation commands pass?"
    },
    "validation_output": {
      "type": "string",
      "description": "Summary of validation results"
    },
    "issues": {
      "type": "array",
      "items": { "type": "string" },
      "description": "Any issues, warnings, or decisions made during execution"
    }
  },
  "required": ["status", "files_created", "files_modified", "tests_passed"]
}
